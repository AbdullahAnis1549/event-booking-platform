@model WebApplication4.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="row justify-content-center py-5" style="background: #f8f9fa; min-height: 80vh;">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__shakeX">
            <div class="card-header bg-danger text-white py-4 text-center">
                <i class="bi bi-exclamation-triangle fs-1 mb-2"></i>
                <h3 class="fw-bold mb-0">Cancel Event?</h3>
            </div>
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <p class="lead text-muted">Are you sure you want to delete this event? This action cannot be undone and all bookings will be lost.</p>
                </div>

                <div class="d-flex align-items-center p-4 bg-light rounded-4 mb-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="rounded-3 me-3" style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                    <div>
                        <h5 class="fw-bold mb-1">@Model.Title</h5>
                        <p class="small text-muted mb-0"><i class="bi bi-calendar-event me-1"></i> @Model.EventDate.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg py-3 rounded-3 shadow-sm fw-bold">
                            Yes, Delete Permanently
                        </button>
                        <a asp-action="Dashboard" asp-controller="Organizer" class="btn btn-link py-2 text-muted">
                            No, Keep it
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
