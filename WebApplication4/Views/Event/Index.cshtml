@model IEnumerable<WebApplication4.Models.Event>

@{
    ViewData["Title"] = "All Events";
}

<div class="bg-light py-5">
    <div class="container-fluid px-4 px-md-5">
        <!-- Search & Filter Header -->
        <!-- Search & Filter Header -->
        <div class="row mb-5 align-items-end">
            <div class="col-12 text-center text-md-start">
                <span class="text-primary fw-bold text-uppercase tracking-wider">Explore</span>
                <h1 class="display-4 fw-bold text-dark">All Events</h1>
                <p class="lead text-muted">Browse our complete collection of past and future events.</p>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                <img src="https://illustrations.popsy.co/amber/paper-plane.svg" alt="No events" style="width: 250px;" class="mb-4" />
                <h3 class="fw-bold">No Events Found</h3>
                <p class="text-muted">There are no approved upcoming events at the moment. Please check back later!</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill">Return Home</a>
            </div>
        }
        else
        {
            <div class="row g-4 ListingContainer">
                @foreach (var item in Model)
                {
                    var isPast = item.EventDate < DateTime.Now;
                    <div class="col-md-6 col-lg-4 animate__animated animate__fadeInUp">
                        <div class="card event-card border-0 shadow-sm rounded-4 h-100 overflow-hidden bg-white">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@item.Title">
                                }
                                else
                                {
                                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 220px;">
                                        <i class="bi bi-image text-white-50 display-1"></i>
                                    </div>
                                }
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-white text-dark shadow-sm px-3 py-2 fw-bold">@item.Price.ToString("C")</span>
                                </div>
                                @if (isPast)
                                {
                                    <div class="position-absolute top-0 start-0 m-3">
                                        <span class="badge bg-secondary px-3 py-2 fw-bold">Completed</span>
                                    </div>
                                }
                                else if (item.AvailableSeats < 10 && item.AvailableSeats > 0)
                                {
                                    <div class="position-absolute top-0 start-0 m-3">
                                        <span class="badge bg-danger px-3 py-2 fw-bold">Only @item.AvailableSeats Left!</span>
                                    </div>
                                }
                            </div>
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="text-primary fw-bold small text-uppercase">
                                        <i class="bi bi-calendar-event me-1"></i> @item.EventDate.ToString("MMM dd")
                                    </div>
                                    <div class="text-muted small">
                                        <i class="bi bi-clock me-1"></i> @item.EventDate.ToString("hh:mm tt")
                                    </div>
                                </div>
                                <h4 class="card-title fw-bold text-dark mb-3">@item.Title</h4>
                                <p class="text-muted small mb-4 text-truncate-2">@item.Description</p>
                                
                                <div class="d-flex align-items-center mb-4">
                                    <div class="bg-light p-2 rounded-circle me-2">
                                        <i class="bi bi-geo-alt-fill text-danger"></i>
                                    </div>
                                    <span class="text-muted small">@item.Location</span>
                                </div>

                                 <div class="d-grid">
                                     <a asp-controller="Event" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary rounded-pill py-2 fw-bold shadow-sm">
                                         View Details
                                     </a>
                                 </div>
                             </div>
                         </div>
                     </div>
                 }
            </div>
        }
    </div>
</div>

<style>
    .event-card {
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .event-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1.5rem 4rem rgba(0,0,0,0.1) !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .btn-white {
        background: #fff;
        border: 1px solid #eee;
        color: #666;
    }
    .btn-white.active {
        background: #d4af37;
        color: #fff;
        border-color: #d4af37;
    }
    .tracking-wider { letter-spacing: 0.1rem; }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
