<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark text-white" style="min-width: 250px; min-height: 100vh;">
            <div class="p-4 border-bottom border-secondary mb-4">
                <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-rocket-takeoff me-2"></i>Eventify Admin</h4>
            </div>
            <div class="list-group list-group-flush px-3">
                <a asp-controller="Admin" asp-action="Dashboard" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2 @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "bg-primary active" : "")">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
                <a asp-controller="Admin" asp-action="OrganizerRequests" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2 @(ViewContext.RouteData.Values["action"]?.ToString() == "OrganizerRequests" ? "bg-primary active" : "")">
                    <i class="bi bi-person-badge me-2"></i> Organizer Requests
                    @* Added simple badge here could be nice if count is available *@
                </a>
                <a asp-controller="Admin" asp-action="ManageUsers" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2">
                    <i class="bi bi-people me-2"></i> Users
                </a>
                <a asp-controller="Admin" asp-action="Events" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2">
                    <i class="bi bi-calendar-event me-2"></i> Events
                </a>

                <a asp-controller="Admin" asp-action="ManageHeroImages" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2">
                    <i class="bi bi-images me-2"></i> Hero Carousel
                </a>
                <a asp-controller="Admin" asp-action="ManageAbout" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2">
                    <i class="bi bi-info-circle me-2"></i> About Page
                </a>
                <a asp-controller="Admin" asp-action="ContactMessages" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2">
                    <i class="bi bi-envelope me-2"></i> Contact Messages
                </a>
                <hr class="border-secondary mb-4" />
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item text-danger border-0 bg-transparent py-2">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </button>
                </form>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3 px-4">
                <div class="container-fluid">
                    <button class="btn btn-primary d-md-none" id="menu-toggle"><i class="bi bi-list"></i></button>
                    <div class="ms-auto d-flex align-items-center">
                         <span class="me-3 text-muted">Welcome, @Context.Session.GetString("UserName")</span>
                         <img src="@(Context.Session.GetString("UserImageUrl") ?? "https://ui-avatars.com/api/?name=Admin")" class="rounded-circle" style="width: 35px; height: 35px; object-fit: cover;" />
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveAdminNotification", function (message) {
            alert("ADMIN NOTIFICATION: " + message);
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
