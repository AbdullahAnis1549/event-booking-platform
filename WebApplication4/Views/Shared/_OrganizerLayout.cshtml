<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Organizer Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark text-white shadow-lg" style="min-width: 250px; min-height: 100vh; border-right: 1px solid rgba(212, 175, 55, 0.2);">
            <div class="p-4 border-bottom border-secondary mb-4 text-center">
                 <div class="rounded-circle overflow-hidden mx-auto mb-3 border border-3 border-warning shadow" style="width: 80px; height: 80px;">
                    <img src="@(Context.Session.GetString("UserImageUrl") ?? "https://ui-avatars.com/api/?name=Organizer")" style="width: 100%; height: 100%; object-fit: cover;" />
                 </div>
                <h5 class="fw-bold mb-0 premium-gradient-text">Organizer Portal</h5>
            </div>
            <div class="list-group list-group-flush px-3">
                <a asp-controller="Organizer" asp-action="Dashboard" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2 sidebar-link active">
                    <i class="bi bi-grid me-2"></i> My Dashboard
                </a>
                <a asp-controller="Event" asp-action="Create" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2 sidebar-link">
                    <i class="bi bi-plus-circle me-2"></i> Create Event
                </a>
                <a asp-controller="Account" asp-action="Profile" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-3 rounded-3 mb-2 sidebar-link">
                    <i class="bi bi-person-gear me-2"></i> Profile Settings
                </a>
                <hr class="border-secondary mb-4" />
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="list-group-item list-group-item-action bg-transparent text-danger border-0 py-2 sidebar-link">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </button>
                </form>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
             <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3 px-4">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold text-dark d-md-none premium-gold-text" href="#">Elite Events</a>
                    <div class="ms-auto">
                        <span class="badge premium-gold-bg py-2 px-3 rounded-pill">Organizer Account</span>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveAdminNotification", function (message) {
             // Some organziers might care or just for consistentcy
             console.log("System Notification: " + message);
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
