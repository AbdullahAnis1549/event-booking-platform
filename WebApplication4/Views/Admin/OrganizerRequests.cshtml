@model IEnumerable<WebApplication4.Models.OrganizerRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Organizer Requests";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">Organizer Requests</h2>
            <p class="text-muted">Manage user requests to become event organizers</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">User</th>
                            <th>Contact Info</th>
                            <th>Requested On</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    No requests found.
                                </td>
                            </tr>
                        }
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(request.User?.ImageUrl) ? "https://ui-avatars.com/api/?name=" + request.User?.Name : request.User?.ImageUrl)" 
                                             class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <div>
                                            <div class="fw-bold">@request.User?.Name</div>
                                            <div class="small text-muted">ID: #@request.UserId</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div><i class="bi bi-envelope me-1"></i> @request.User?.Email</div>
                                        <div><i class="bi bi-telephone me-1"></i> @request.User?.Phone</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">@request.RequestDate.ToString("MMM dd, yyyy")</div>
                                    <div class="text-muted small">@request.RequestDate.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    @if (request.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Pending</span>
                                    }
                                    else if (request.Status == "Approved")
                                    {
                                        <span class="badge bg-success px-3 py-2 rounded-pill">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill">Rejected</span>
                                        @if (!string.IsNullOrEmpty(request.AdminComment))
                                        {
                                            <div class="small text-muted mt-1" title="@request.AdminComment">
                                                <i class="bi bi-info-circle"></i> Reason added
                                            </div>
                                        }
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (request.Status == "Pending")
                                    {
                                        <div class="btn-group">
                                            <form asp-action="ApproveOrganizerRequest" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success me-2" onclick="return confirm('Are you sure you want to approve this request?')">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@request.Id">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>

                                        <!-- Reject Modal -->
                                        <div class="modal fade" id="rejectModal-@request.Id" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title fw-bold">Reject Request</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form asp-action="RejectOrganizerRequest" method="post">
                                                        <div class="modal-body text-start">
                                                            <input type="hidden" name="id" value="@request.Id" />
                                                            <p>Are you sure you want to reject @request.User?.Name's request?</p>
                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold">Reason for Rejection (Optional)</label>
                                                                <textarea name="adminComment" class="form-control" rows="3" placeholder="Tell the user why their request was rejected..."></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Processed</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding-top: 1rem;
        padding-bottom: 1rem;
    }
    
    .card {
        border-radius: 15px;
        overflow: hidden;
    }

    .badge {
        font-weight: 500;
    }
</style>
