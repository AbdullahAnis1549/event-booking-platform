@model IEnumerable<WebApplication4.Models.ContactMessage>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Contact Messages";
    var unreadCount = Model.Count(m => !m.IsRead);
}

<div class="container py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold text-dark border-start border-4 border-primary ps-3">Contact Messages</h2>
            <p class="text-muted">View and manage messages from users.</p>
        </div>
        <div class="col-auto">
            @if (unreadCount > 0)
            {
                <span class="badge bg-danger rounded-pill px-3 py-2">@unreadCount Unread</span>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-envelope text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-4 fw-bold">No Messages Yet</h3>
            <p class="text-muted">Contact messages from users will appear here.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var message in Model)
            {
                <div class="col-12">
                    <div class="card shadow-sm border-0 rounded-4 @(message.IsRead ? "" : "border-start border-4 border-primary")">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <div class="d-flex align-items-center mb-2">
                                        <h5 class="card-title fw-bold mb-0 me-3">@message.Name</h5>
                                        @if (!message.IsRead)
                                        {
                                            <span class="badge bg-primary">New</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Read</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-envelope me-1"></i>@message.Email
                                    </p>
                                    @if (!string.IsNullOrEmpty(message.Subject))
                                    {
                                        <p class="text-muted small mb-0">
                                            <i class="bi bi-tag me-1"></i>@message.Subject
                                        </p>
                                    }
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block mb-2">
                                        <i class="bi bi-clock me-1"></i>@message.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    </small>
                                    <div class="btn-group">
                                        <form asp-action="MarkMessageAsRead" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@message.Id" />
                                            <button type="submit" class="btn btn-outline-@(message.IsRead ? "secondary" : "primary") btn-sm rounded-pill">
                                                <i class="bi bi-@(message.IsRead ? "envelope" : "envelope-check") me-1"></i>
                                                @(message.IsRead ? "Mark Unread" : "Mark Read")
                                            </button>
                                        </form>
                                        <form asp-action="DeleteContactMessage" method="post" class="d-inline" onsubmit="return confirm('Delete this message?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@message.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">
                                                <i class="bi bi-trash me-1"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="bg-light p-3 rounded-3 mt-3">
                                <p class="mb-0" style="white-space: pre-wrap;">@message.Message</p>
                            </div>
                            <div class="mt-3 pt-3 border-top">
                                <a href="mailto:@message.Email?subject=Re: @(message.Subject ?? "Your Contact Message")" class="btn btn-primary btn-sm rounded-pill">
                                    <i class="bi bi-reply me-1"></i> Reply via Email
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
