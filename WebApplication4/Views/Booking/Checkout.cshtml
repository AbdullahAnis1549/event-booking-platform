@model WebApplication4.Models.Booking
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-4 text-center">
                    <h3 class="fw-bold mb-0">Booking Invoice</h3>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-receipt-cutoff display-1 text-primary"></i>
                    </div>

                    <div class="mb-4 text-center">
                        <h4 class="text-muted small text-uppercase fw-bold">Event Details</h4>
                        <h2 class="fw-bold text-dark">@Model.Event?.Title</h2>
                        <p class="text-muted"><i class="bi bi-geo-alt-fill me-1"></i>@Model.Event?.Location</p>
                    </div>

                    <div class="list-group list-group-flush mb-4 border rounded-3 overflow-hidden">
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted">Tickets</span>
                            <span class="fw-bold">@Model.NumberOfTickets</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted">Price per Ticket</span>
                            <span class="fw-bold">@Model.Event?.Price.ToString("C")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-light">
                            <span class="h5 mb-0 fw-bold">Total Bill</span>
                            <span class="h4 mb-0 fw-bold text-primary">@Model.TotalAmount.ToString("C")</span>
                        </div>
                    </div>

                    <form asp-action="ProcessPayment" asp-controller="Booking" method="post" id="payment-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@Model.Id" />
                        
                        <div class="alert alert-warning border-0 rounded-3 mb-4 small">
                            <i class="bi bi-info-circle-fill me-2"></i> By clicking the button below, you confirm your booking for this event.
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm" id="pay-btn">
                            <span id="btn-text">Confirm & Pay Bill</span>
                            <span id="btn-loader" class="d-none">
                                <span class="spinner-border spinner-border-sm me-2"></span> Processing...
                            </span>
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">
                            <i class="bi bi-x-circle me-1"></i> Cancel Booking
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#payment-form').on('submit', function() {
                $('#btn-text').addClass('d-none');
                $('#btn-loader').removeClass('d-none');
                $('#pay-btn').prop('disabled', true);
            });
        });
    </script>
}

