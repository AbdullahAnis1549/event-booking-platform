@model IEnumerable<WebApplication4.Models.Booking>
@{
    ViewData["Title"] = "My Tickets";
    var userName = Context.Session.GetString("UserName");
}

<div class="container-fluid py-5" style="background: #f0f2f5; min-height: 100vh;">
    <div class="container">
        <div class="row mb-5">
            <div class="col">
                <h2 class="fw-bold text-dark border-start border-4 border-info ps-3">My Booked Tickets</h2>
                <p class="text-muted">You have <strong>@Model.Count()</strong> active registration(s).</p>
            </div>
        </div>

        <div class="row g-4">
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-ticket-perforated text-muted" style="font-size: 5rem;"></i>
                    </div>
                    <h3>No Bookings Found</h3>
                    <p class="text-muted mb-4">You haven't registered for any events yet. Explore events and get your first ticket!</p>
                    <a asp-controller="Event" asp-action="Index" class="btn btn-primary btn-lg shadow">Browse Events</a>
                </div>
            }

            @foreach (var item in Model)
            {
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 flex-row">
                        <div class="d-none d-md-block" style="width: 200px; position: relative;">
                            @if (!string.IsNullOrEmpty(item.Event?.ImageUrl))
                            {
                                <img src="@item.Event.ImageUrl" class="h-100 w-100" style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="h-100 w-100 bg-secondary d-flex align-items-center justify-content-center">
                                    <i class="bi bi-image text-white-50 fs-1"></i>
                                </div>
                            }
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">@item.Status</span>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <div class="flex-grow-1">
                                <h4 class="fw-bold mb-1 text-primary">@item.Event?.Title</h4>
                                <p class="text-muted small mb-3">
                                    <i class="bi bi-geo-alt me-1"></i> @item.Event?.Location
                                </p>

                                <div class="row g-3 mb-3 text-center">
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded-3">
                                            <small class="text-muted d-block uppercase fs-xs">Event Date</small>
                                            <span class="fw-bold">@item.Event?.EventDate.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded-3">
                                            <small class="text-muted d-block uppercase fs-xs">Tickets</small>
                                            <span class="fw-bold">@item.NumberOfTickets Person(s)</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-end mt-4 pt-3 border-top">
                                    <div>
                                        <small class="text-muted d-block">Booking ID: #@item.Id</small>
                                        <small class="text-muted d-block">Booked on: @item.BookingDate.ToString("MMM dd, hh:mm tt")</small>
                                    </div>
                                    <div class="text-end">
                                        <small class="text-muted d-block">Total Paid</small>
                                        <h4 class="fw-bold text-success mb-0">@item.TotalAmount.ToString("C")</h4>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-4">
                                <a asp-controller="Event" asp-action="Details" asp-route-id="@item.EventId" class="btn btn-outline-primary btn-sm w-100 rounded-pill">
                                    View Event Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fs-xs { font-size: 0.7rem; letter-spacing: 0.05rem; text-transform: uppercase; }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
