@{
    ViewData["Title"] = "Reset Password";
    var email     = ViewBag.Email as string ?? TempData["UserEmail"]?.ToString();
    var resetCode = ViewBag.ResetCode as string ?? TempData["ResetCode"]?.ToString();
}

<div class="row justify-content-center align-items-center" style="min-height:70vh;">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__fadeIn">
            <div class="card-header premium-gold-bg text-white py-4 text-center">
                <i class="bi bi-shield-lock fs-1 mb-2 d-block text-white"></i>
                <h3 class="fw-bold mb-0 text-white">Reset Password</h3>
                <p class="mb-0 text-white opacity-75">Create a new secure password for your account</p>
            </div>
            <div class="card-body p-4 p-md-5">
                <p class="text-muted text-center mb-4">
                    Setting new password for <strong>@email</strong>
                </p>

                <form asp-action="ResetPassword" method="post" id="resetForm" novalidate>
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="email"     value="@email" />
                    <input type="hidden" name="resetCode" value="@resetCode" />

                    {{!-- New Password --}}
                    <div class="mb-4">
                        <label for="newPassword" class="form-label fw-bold">New Password</label>
                        <div class="input-group has-validation">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-lock"></i></span>
                            <input type="password" name="newPassword" id="newPassword"
                                   class="form-control bg-light border-0 py-3"
                                   placeholder="Min. 6 characters" autofocus />
                            <button class="btn btn-outline-secondary border-0 bg-light" type="button"
                                    id="toggleNew" tabindex="-1">
                                <i class="bi bi-eye" id="eyeNew"></i>
                            </button>
                            <div class="invalid-feedback" id="newPassError"></div>
                        </div>
                        <div class="mt-2" id="strengthBar" style="display:none;">
                            <div class="progress" style="height:6px;">
                                <div id="strengthFill" class="progress-bar" role="progressbar" style="width:0%;"></div>
                            </div>
                            <small id="strengthLabel" class="text-muted"></small>
                        </div>
                    </div>

                    {{!-- Confirm Password --}}
                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label fw-bold">Confirm Password</label>
                        <div class="input-group has-validation">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-shield-check"></i></span>
                            <input type="password" name="confirmPassword" id="confirmPassword"
                                   class="form-control bg-light border-0 py-3"
                                   placeholder="Repeat new password" />
                            <button class="btn btn-outline-secondary border-0 bg-light" type="button"
                                    id="toggleConfirm" tabindex="-1">
                                <i class="bi bi-eye" id="eyeConfirm"></i>
                            </button>
                            <div class="invalid-feedback" id="confirmError"></div>
                        </div>
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i>
                            <div>
                                @foreach (var error in ViewData.ModelState[""]?.Errors)
                                {
                                    <p class="mb-0 small">@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg py-3 rounded-pill fw-bold shadow">
                            Reset Password
                        </button>
                    </div>
                </form>

                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none premium-gold-text fw-bold small">
                        <i class="bi bi-arrow-left me-1"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            const form        = document.getElementById('resetForm');
            const newPassEl   = document.getElementById('newPassword');
            const confirmEl   = document.getElementById('confirmPassword');

            // ── Toggle visibility ───────────────────────────────────────
            function setupToggle(btnId, inputId, iconId) {
                document.getElementById(btnId).addEventListener('click', function () {
                    const inp  = document.getElementById(inputId);
                    const icon = document.getElementById(iconId);
                    const isPwd = inp.type === 'password';
                    inp.type = isPwd ? 'text' : 'password';
                    icon.classList.toggle('bi-eye',       !isPwd);
                    icon.classList.toggle('bi-eye-slash',  isPwd);
                });
            }
            setupToggle('toggleNew',     'newPassword',     'eyeNew');
            setupToggle('toggleConfirm', 'confirmPassword', 'eyeConfirm');

            // ── Password strength meter ─────────────────────────────────
            newPassEl.addEventListener('input', function () {
                const val        = this.value;
                const bar        = document.getElementById('strengthBar');
                const fill       = document.getElementById('strengthFill');
                const label      = document.getElementById('strengthLabel');

                if (val.length === 0) { bar.style.display = 'none'; return; }
                bar.style.display = 'block';

                let score = 0;
                if (val.length >= 6)  score++;
                if (val.length >= 10) score++;
                if (/[A-Z]/.test(val)) score++;
                if (/[0-9]/.test(val)) score++;
                if (/[^A-Za-z0-9]/.test(val)) score++;

                const levels = [
                    { pct: 20,  color: 'bg-danger',  text: 'Very Weak'  },
                    { pct: 40,  color: 'bg-warning',  text: 'Weak'       },
                    { pct: 60,  color: 'bg-info',     text: 'Fair'       },
                    { pct: 80,  color: 'bg-primary',  text: 'Strong'     },
                    { pct: 100, color: 'bg-success',  text: 'Very Strong'},
                ];
                const lvl = levels[Math.min(score, 4)];
                fill.style.width = lvl.pct + '%';
                fill.className   = 'progress-bar ' + lvl.color;
                label.textContent = 'Strength: ' + lvl.text;

                // Re-check confirm if already touched
                if (confirmEl.value !== '') validateConfirm();
            });

            // ── Validators ──────────────────────────────────────────────
            function validateNew() {
                const val = newPassEl.value;
                if (val === '') {
                    setInvalid(newPassEl, 'newPassError', 'New password is required.'); return false;
                } else if (val.length < 6) {
                    setInvalid(newPassEl, 'newPassError', 'Password must be at least 6 characters.'); return false;
                }
                setValid(newPassEl); return true;
            }

            function validateConfirm() {
                const val = confirmEl.value;
                if (val === '') {
                    setInvalid(confirmEl, 'confirmError', 'Please confirm your new password.'); return false;
                } else if (newPassEl.value !== val) {
                    setInvalid(confirmEl, 'confirmError', 'Passwords do not match.'); return false;
                }
                setValid(confirmEl); return true;
            }

            function setInvalid(el, errorId, msg) {
                el.classList.remove('is-valid');
                el.classList.add('is-invalid');
                const err = document.getElementById(errorId);
                if (err) err.textContent = msg;
            }

            function setValid(el) {
                el.classList.remove('is-invalid');
                el.classList.add('is-valid');
            }

            // ── Blur & input listeners ──────────────────────────────────
            newPassEl.addEventListener('blur',  validateNew);
            confirmEl.addEventListener('blur',  validateConfirm);
            confirmEl.addEventListener('input', function () {
                if (this.classList.contains('is-invalid') || this.classList.contains('is-valid')) validateConfirm();
            });

            // ── Submit ──────────────────────────────────────────────────
            form.addEventListener('submit', function (e) {
                const ok = [validateNew(), validateConfirm()];
                if (ok.includes(false)) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });
        })();
    </script>
}
